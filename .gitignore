# =====================================
# Kubernetes
# =====================================

# Kubeconfig local
.kube/
kubeconfig
config.local

# Helm
charts/*/charts/
charts/*/tmp/
*.tgz

# Kustomize
.kustomize/

# =====================================
# Node.js (caso haja scripts auxiliares)
# =====================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =====================================
# Variáveis de ambiente
# =====================================
.env
.env.*
!.env.example

# =====================================
# Arquivos temporários
# =====================================
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# =====================================
# IDEs
# =====================================
.vscode/
.idea/

# =====================================
# Sistema Operacional
# =====================================
.DS_Store
Thumbs.db

# =====================================
# Credenciais e certificados
# =====================================
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# =====================================
# Terraform (se usado)
# =====================================
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# =====================================
# Arquivos gerados
# =====================================
coverage/
.cache/
dist/
build/

# =====================================
# Manifests Kubernetes
# NÃO ignore estes arquivos
# =====================================
!*.yaml
!*.yml
!*.sh
!*.js